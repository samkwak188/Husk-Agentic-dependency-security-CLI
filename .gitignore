# ─── Secrets & per-machine config (NEVER commit) ────────────────────────────
.env
.env.local
.env.*.local

# `.npmrc` is rewritten by `husk intercept --enable` to point at the local
# proxy. Committing it would break every clone that runs `npm install`.
.npmrc

# Husk runtime state (intercept proxy pid / log / tty path).
# Lives under ~/.husk now, but earlier builds wrote it here too.
.husk/

# ─── Build artifacts ────────────────────────────────────────────────────────
# `dist/` is generated by `npm run build`. The package.json `prepare` script
# regenerates it after every `npm install`, so consumers don't need it
# checked in. Skipping it keeps diffs clean and the repo small.
dist/
*.tsbuildinfo

# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/

# ─── Datasets (huge, fetched by `npm run setup`) ────────────────────────────
# 33 GB combined. The benchmark loader clones them on demand via setup.sh.
datasets/datadog/
datasets/backstabbers/

# ─── Test / scan output ─────────────────────────────────────────────────────
test-output/
coverage/
.nyc_output/

# ─── Editor / OS noise ──────────────────────────────────────────────────────
.DS_Store
.tmp/
*.log
*.swp
.vscode/
.idea/
.cursor/

# ─── tmp / scratch ──────────────────────────────────────────────────────────
/tmp-*
