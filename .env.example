# This is how .env is configured.
AI_PROVIDER=openrouter

# OpenRouter configuration
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-5-mini
OPENROUTER_MODEL_DYNAMIC=openai/gpt-5-nano
OPENROUTER_MODEL_REPORTER=openai/gpt-5-nano
# Husk will automatically fail over to stable OpenRouter-compatible models
# if the configured model returns empty output or unsupported-parameter errors.
# Optional comma-separated stage fallback overrides:
# OPENROUTER_MODEL_FALLBACKS=openai/gpt-4.1-mini,openrouter/auto
# OPENROUTER_MODEL_TRIAGE_FALLBACKS=openai/gpt-4.1-mini,openrouter/auto
# OPENROUTER_MODEL_DYNAMIC_FALLBACKS=openai/gpt-4.1-mini,openrouter/auto
# OPENROUTER_MODEL_REPORTER_FALLBACKS=openai/gpt-4.1-mini,openrouter/auto
# Optional attribution headers for OpenRouter leaderboards/analytics
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=Husk

# Optional generic overrides used by either provider
# AI_MODEL=
# AI_MODEL_TRIAGE=
# AI_MODEL_DYNAMIC=
# AI_MODEL_REPORTER=
# AI_MAX_RETRIES=2
# AI_RETRY_BASE_MS=1200

# OpenAI configuration
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-5.1
# OPENAI_MODEL_DYNAMIC=gpt-5-mini
# OPENAI_MODEL_REPORTER=gpt-5-mini

PORT=3000
